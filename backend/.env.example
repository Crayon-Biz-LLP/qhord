PORT=4000
NODE_ENV=development

# PostgreSQL connection
DATABASE_URL=postgres://postgres:postgres@postgres:5432/control_tower

# Authentication
JWT_SECRET=replace-with-strong-jwt-secret
BCRYPT_SALT_ROUNDS=12

# Encryption key for API keys (32+ chars recommended)
ENCRYPTION_SECRET=replace-with-strong-encryption-secret

# External tool base URLs (customize per environment)
APOLLO_BASE_URL=https://api.apollo.io
CLAY_BASE_URL=https://api.clay.run
HEYREACH_BASE_URL=https://api.heyreach.io
SMARTLY_BASE_URL=https://api.smartly.io
